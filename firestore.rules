rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          request.auth.token.email.lower() == "cbenedetti@benedetti.com" ||
          request.auth.token.email.lower() == "naturalsoft@gmail.com"
        );
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['address', 'phoneLine', 'phoneWhatsapp', 'hoursTueThu', 'hoursMonWedFri', 'aboutHero', 'aboutText']) &&
             data.address is string && data.address.size() < 200 &&
             data.phoneLine is string && data.phoneLine.size() < 50 &&
             data.phoneWhatsapp is string && data.phoneWhatsapp.size() < 50 &&
             data.hoursTueThu is string && data.hoursTueThu.size() < 100 &&
             data.hoursMonWedFri is string && data.hoursMonWedFri.size() < 100 &&
             data.aboutHero is string && data.aboutHero.size() < 500 &&
             data.aboutText is string && data.aboutText.size() < 10000 &&
             (!('instagramUrl' in data) || data.instagramUrl is string) &&
             (!('facebookUrl' in data) || data.facebookUrl is string) &&
             (!('linkedinUrl' in data) || data.linkedinUrl is string);
    }

    function isValidReview(data) {
      return data.keys().hasAll(['id', 'author', 'rating', 'text', 'createdAt']) &&
             data.id is string &&
             data.author is string && data.author.size() > 0 && data.author.size() < 100 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000 &&
             data.createdAt is string;
    }

    function isValidProfessional(data) {
      return data.keys().hasAll(['name', 'specialties', 'image', 'bio', 'availability']) &&
             data.name is string && data.name.size() < 100 &&
             data.specialties is list &&
             data.image is string && data.image.size() < 500 &&
             data.bio is string && data.bio.size() < 10000 &&
             data.availability is string && data.availability.size() < 200 &&
             (!('education' in data) || data.education is list) &&
             (!('experience' in data) || data.experience is list) &&
             (!('specializations' in data) || data.specializations is list);
    }

    function isValidInsurance(data) {
      return data.keys().hasAll(['name', 'logo', 'specialties']) &&
             data.name is string && data.name.size() < 100 &&
             data.logo is string && data.logo.size() < 500 &&
             data.specialties is list;
    }

    function isValidBlogPost(data) {
      return data.keys().hasAll(['title', 'excerpt', 'content', 'date', 'category', 'image']) &&
             data.title is string && data.title.size() < 200 &&
             data.excerpt is string && data.excerpt.size() < 500 &&
             data.content is string && data.content.size() < 50000 &&
             data.date is string &&
             data.category is string && data.category.size() < 100 &&
             data.image is string && data.image.size() < 500;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /settings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin() && (request.method == 'delete' || isValidSettings(request.resource.data));
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if isAdmin() && (request.method == 'delete' || isValidReview(request.resource.data));
    }

    match /professionals/{id} {
      allow read: if true;
      allow write: if isAdmin() && (request.method == 'delete' || isValidProfessional(request.resource.data));
    }

    match /insurances/{id} {
      allow read: if true;
      allow write: if isAdmin() && (request.method == 'delete' || isValidInsurance(request.resource.data));
    }

    match /blog/{id} {
      allow read: if true;
      allow write: if isAdmin() && (request.method == 'delete' || isValidBlogPost(request.resource.data));
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId && 
                    (request.auth.token.email.lower() == "cbenedetti@benedetti.com" || isAdmin());
      allow update: if isAdmin();
    }
  }
}
