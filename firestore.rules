rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin' ||
         (request.auth.token.email == "naturalsoft@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['address', 'phoneLine', 'phoneWhatsapp', 'hoursTueThu', 'hoursMonWedFri']) &&
             data.address is string && data.address.size() < 200 &&
             data.phoneLine is string && data.phoneLine.size() < 50 &&
             data.phoneWhatsapp is string && data.phoneWhatsapp.size() < 50 &&
             data.hoursTueThu is string && data.hoursTueThu.size() < 100 &&
             data.hoursMonWedFri is string && data.hoursMonWedFri.size() < 100;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /settings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId && request.resource.data.role == 'admin' && isAdmin();
      allow update: if isAdmin();
    }
  }
}
