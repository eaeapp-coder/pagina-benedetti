{
  "entities": {
    "Settings": {
      "title": "Settings",
      "description": "Global application settings like contact info and business hours",
      "type": "object",
      "properties": {
        "address": { "type": "string", "description": "Physical address" },
        "phoneLine": { "type": "string", "description": "Landline phone number" },
        "phoneWhatsapp": { "type": "string", "description": "WhatsApp phone number" },
        "hoursTueThu": { "type": "string", "description": "Hours for Tue and Thu" },
        "hoursMonWedFri": { "type": "string", "description": "Hours for Mon, Wed, Fri" },
        "aboutHero": { "type": "string", "description": "Hero text for the About Us page" },
        "aboutText": { "type": "string", "description": "Main text for the About Us page" },
        "instagramUrl": { "type": "string", "description": "Instagram profile URL" },
        "facebookUrl": { "type": "string", "description": "Facebook profile URL" },
        "linkedinUrl": { "type": "string", "description": "LinkedIn profile URL" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["address", "phoneLine", "phoneWhatsapp", "hoursTueThu", "hoursMonWedFri", "aboutHero", "aboutText"]
    },
    "User": {
      "title": "User",
      "description": "User profile for administration",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Review": {
      "title": "Review",
      "description": "Customer review for the testimonials section",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "author": { "type": "string" },
        "rating": { "type": "number" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "author", "rating", "text", "createdAt"]
    },
    "Professional": {
      "title": "Professional",
      "description": "Medical professional profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "specialties": { "type": "array", "items": { "type": "string" } },
        "image": { "type": "string" },
        "bio": { "type": "string" },
        "education": { "type": "array", "items": { "type": "string" } },
        "experience": { "type": "array", "items": { "type": "string" } },
        "specializations": { "type": "array", "items": { "type": "string" } },
        "languages": { "type": "array", "items": { "type": "string" } },
        "availability": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "specialties", "image"]
    },
    "Insurance": {
      "title": "Insurance",
      "description": "Health insurance provider",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logo": { "type": "string" },
        "specialties": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "logo", "specialties"]
    },
    "BlogPost": {
      "title": "BlogPost",
      "description": "Blog article document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "category": { "type": "string" },
        "image": { "type": "string" }
      },
      "required": ["title", "excerpt", "content", "date", "category", "image"]
    }
  },
  "firestore": {
    "/settings/{settingsId}": {
      "schema": "Settings",
      "description": "Global settings document"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Customer review documents"
    },
    "/professionals/{professionalId}": {
      "schema": "Professional",
      "description": "Professional profile documents"
    },
    "/insurances/{insuranceId}": {
      "schema": "Insurance",
      "description": "Insurance provider documents"
    },
    "/blog/{postId}": {
      "schema": "BlogPost",
      "description": "Blog article documents"
    }
  }
}
