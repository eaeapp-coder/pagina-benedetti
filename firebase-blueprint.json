{
  "entities": {
    "Settings": {
      "title": "Settings",
      "description": "Global application settings like contact info and business hours",
      "type": "object",
      "properties": {
        "address": { "type": "string", "description": "Physical address" },
        "phoneLine": { "type": "string", "description": "Landline phone number" },
        "phoneWhatsapp": { "type": "string", "description": "WhatsApp phone number" },
        "hoursTueThu": { "type": "string", "description": "Hours for Tue and Thu" },
        "hoursMonWedFri": { "type": "string", "description": "Hours for Mon, Wed, Fri" },
        "aboutHero": { "type": "string", "description": "Hero text for the About Us page" },
        "aboutText": { "type": "string", "description": "Main text for the About Us page" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["address", "phoneLine", "phoneWhatsapp", "hoursTueThu", "hoursMonWedFri", "aboutHero", "aboutText"]
    },
    "User": {
      "title": "User",
      "description": "User profile for administration",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Review": {
      "title": "Review",
      "description": "Customer review for the testimonials section",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "author": { "type": "string" },
        "rating": { "type": "number" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "author", "rating", "text", "createdAt"]
    }
  },
  "firestore": {
    "/settings/{settingsId}": {
      "schema": "Settings",
      "description": "Global settings document"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Customer review documents"
    }
  }
}
